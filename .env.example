# Required — get free from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required — get free (no card) from https://app.tavily.com
TAVILY_API_KEY=

# Optional — only needed if you want memory synced across devices (phone + PC)
# Get free from https://supabase.com -> Project Settings -> API
# Use the "service_role" key (NOT the anon/public key) — keep it secret, backend-only.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
